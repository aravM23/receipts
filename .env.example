# ───────────────────────────────────────────────────────────────────
# STANLEY+ receipt cards — environment
# Copy to .env.local and fill in. .env* is gitignored.
# ───────────────────────────────────────────────────────────────────

# --- Data + LLM (required for real cards on / ) ---
# HikerAPI key (public IG scraping). Aka LAMADAVA_API_KEY.
HIKER_API_KEY=
# OpenRouter / OpenAI-compatible key for insight/type/drink generation.
# Without it, generation falls back to rule-based copy.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o

# Base URL the printed QR encodes (else inferred from the request).
NEXT_PUBLIC_SITE_URL=

# --- Persistence (prod) ---
# Set these (or the KV_REST_API_* equivalents) to use Upstash Redis.
# If unset, the app uses a local JSON file at ./data/store.json.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ───────────────────────────────────────────────────────────────────
# Print worker (scripts/print-worker.mjs) — runs on the machine the
# printer is plugged into. The kiosk/browser never prints directly;
# it enqueues a job and this worker drains the queue. No print dialog.
# ───────────────────────────────────────────────────────────────────

# Shared secret; must match the value the app/server sees.
PRINT_WORKER_TOKEN=dev-print-token
# Where the worker reaches the app/API (the queue lives here).
BASE_URL=http://localhost:3000
# What the printed QR resolves to — must be reachable from a guest's PHONE
# (a LAN IP or the public domain). Defaults to BASE_URL.
PUBLIC_BASE_URL=

# --- Mode 1: LABEL / CUPS (MUNBYN 4x6 Bluetooth/USB & similar) ---
# CUPS queue name of the label printer. Find it with: lpstat -p
# Connect the MUNBYN over USB (its Bluetooth is iOS/Android-only) and install
# the MUNBYN Mac driver, then set this. The worker prints the on-screen
# receipt PNG silently via `lp`.
PRINTER_NAME=
# Optional CUPS media size for the label, e.g. Custom.4x6in
PRINT_MEDIA=Custom.4x6in
# Extra raw `lp` options (default fits the image to the label).
PRINT_LP_OPTS=-o fit-to-page

# --- Mode 2: ESC/POS raw (legacy 58/80mm receipt printers) ---
# Raw device path. Used only when PRINTER_NAME is NOT set.
PRINTER_DEVICE=
RECEIPT_COLS=42
QR_SIZE=7

# Poll interval for the worker (ms).
POLL_MS=2000
